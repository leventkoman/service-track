{
  "compilerOptions": {
    "target": "es2020",
//    "types": ["vuetify"],
    "typeRoots": [
      "./api/src/types", 
      "./node_modules/@types"
    ],
    "types": ["node", "express"],
    "module": "commonjs",
    "lib": ["es2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@stf/components/common/*": ["web/src/components/common/*"],
      "@stf/components/layout/*": ["web/src/components/layout/*"],
      "@stf/features/*": ["web/src/features/*"],
      "@stf/hooks/*": ["web/src/hooks/*"],
      "@stf/lib/*": ["web/src/lib/*"],
      "@stf/models/*": ["web/src/models/*"],
      "@stf/pages/*": ["web/src/pages/*"],
      "@stf/store/*": ["web/src/store/*"],
      "@stf/utils/*": ["web/src/utils/*"],
      "@sts/schemas/*": ["shared/schemas/*"],
      "@sts/models/*": ["shared/models/*"],
      "@stb/controllers/*": ["api/src/controllers/*"],
      "@stb/services/*": ["api/src/services/*"]
    }
  },
  "include": [
    "api/**/*",
    "src/**/*",
    "shared/**/*",
    "web/**/*"
  ]
}